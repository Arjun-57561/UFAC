# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# UFAC Engine v2.0 - Environment Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ══════════════════════════════════════════════════════════════════════════════
# ⚠️  REQUIRED CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════

# Groq API Configuration (llama-3.3-70b-versatile)
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here


# ══════════════════════════════════════════════════════════════════════════════
# 🔒 SECURITY CONFIGURATION (New in v2.0)
# ══════════════════════════════════════════════════════════════════════════════

# CORS - Comma-separated list of allowed origins
# Local development:
ALLOWED_ORIGINS=http://localhost:3000
# Production (add your domains):
# ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com,https://your-domain.vercel.app

# ══════════════════════════════════════════════════════════════════════════════
# ⚡ PERFORMANCE CONFIGURATION (New in v2.0)
# ══════════════════════════════════════════════════════════════════════════════

# LLM Timeout (seconds) - How long to wait for LLM API responses
LLM_TIMEOUT_SECONDS=15.0

# Cache TTL (Time-To-Live in seconds)
CACHE_TTL_ASSESSMENT=3600  # Assessment cache: 1 hour
CACHE_TTL_RAG=7200          # RAG context cache: 2 hours  
CACHE_TTL_LLM=3600          # LLM response cache: 1 hour

# ══════════════════════════════════════════════════════════════════════════════
# 🗄️  DATABASE CONFIGURATION (Phase 4)
# ══════════════════════════════════════════════════════════════════════════════

# Database URL - SQLite by default, can use PostgreSQL for production
# DATABASE_URL=sqlite+aiosqlite:///./ufac_engine.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/ufac_db

# ══════════════════════════════════════════════════════════════════════════════
# 🛠️  OPTIONAL: DEVELOPMENT SETTINGS
# ══════════════════════════════════════════════════════════════════════════════

# Development Mode - Reduces LLM calls from 3 to 1 for faster testing
# Saves API quota during development
# DEV_MODE=true

# ══════════════════════════════════════════════════════════════════════════════
# 🚀 OPTIONAL: FASTAPI CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════

# API_HOST=0.0.0.0
# API_PORT=8000
# API_RELOAD=true

# ══════════════════════════════════════════════════════════════════════════════
# 📝 OPTIONAL: LOGGING CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════

# LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
